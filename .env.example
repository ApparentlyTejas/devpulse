# =============================================================================
# DevPulse — environment template
# Copy to `.env` for local development. NEVER commit a real .env.
# Every variable consumed by the app must be documented here.
# =============================================================================

# ---- App ----
APP_ENV=local            # local | dev | staging | prod
APP_NAME=devpulse
APP_DEBUG=true
APP_LOG_LEVEL=INFO       # DEBUG | INFO | WARNING | ERROR

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
API_V1_PREFIX=/api/v1
# Comma-separated origins allowed by CORS. Use exact origins; never "*".
API_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Security ----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECURITY_JWT_SECRET=change-me-to-a-long-random-string
SECURITY_JWT_ALGORITHM=HS256
SECURITY_JWT_ACCESS_TOKEN_TTL_SECONDS=900       # 15 min
SECURITY_JWT_REFRESH_TOKEN_TTL_SECONDS=2592000  # 30 days

# ---- Postgres ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=devpulse
POSTGRES_PASSWORD=devpulse
POSTGRES_DB=devpulse
# SQLAlchemy async URL; built from the parts above by config.py.
# DATABASE_URL=postgresql+asyncpg://devpulse:devpulse@postgres:5432/devpulse

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# REDIS_URL=redis://redis:6379/0

# ---- AI ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
